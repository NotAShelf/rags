{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": ["src"],
    "entryPointStrategy": "expand",
    "out": "docs/html",
    "exclude": ["**/*.spec.ts", "**/*.test.ts"],
    "excludePrivate": true,
    "excludeInternal": true,
    "includeVersion": true,
    "name": "RAGS",
    "readme": "README.md",
    "tsconfig": "tsconfig.json",
    "skipErrorChecking": true,
    "plugin": ["typedoc-rhineai-theme"],
    "navigation": {
        "includeCategories": true,
        "includeGroups": true
    },
    "searchInComments": true,
    "categorizeByGroup": true,
    "highlightLanguages": ["bash", "c", "js", "json", "ts", "typescript", "javascript"],
    "intentionallyNotExported": [
        "Anchor",
        "Args",
        "B",
        "BarMode",
        "Bind",
        "CairoContext",
        "Camel",
        "CommonProps",
        "Connection",
        "Cursor",
        "Dep",
        "Detail",
        "DrawFn",
        "Event",
        "EventHandler",
        "Exclusivity",
        "Flags",
        "Ico",
        "Instance",
        "Justification",
        "Kebab",
        "Keymode",
        "Layer",
        "Listen",
        "LoopStatus",
        "Mark",
        "MenuEventHandler",
        "MprisMetadata",
        "NotifcationJson",
        "PlaybackStatus",
        "Policy",
        "Poll",
        "PowerProfiles",
        "Property",
        "Response",
        "Services",
        "Transition",
        "Truncate"
    ]
}
