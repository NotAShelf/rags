{
    "$schema": "https://typedoc.org/schema.json",
    "entryPoints": ["src"],
    "entryPointStrategy": "expand",
    "out": "docs/html",
    "exclude": ["**/*.spec.ts", "**/*.test.ts"],
    "excludePrivate": true,
    "excludeInternal": true,
    "includeVersion": true,
    "name": "RAGS",
    "readme": "docs/index.md",
    "tsconfig": "tsconfig.json",
    "skipErrorChecking": true,
    "excludeExternals": true,
    "plugin": ["typedoc-rhineai-theme"],
    "navigation": {
        "includeCategories": true,
        "includeGroups": true
    },
    "projectDocuments": ["docs/guides/**/*.md"],
    "searchInComments": true,
    "searchInDocuments": true,
    "categorizeByGroup": true,
    "sort": ["documents-first", "kind", "instance-first", "alphabetical-ignoring-documents"],
    "categoryOrder": ["Guides", "*"],
    "groupOrder": ["Getting Started", "Configuration", "Advanced", "Services", "*"],
    "customJs": "docs/assets/nav-expand.js",
    "customCss": "docs/assets/custom.css",
    "highlightLanguages": [
        "bash",
        "c",
        "css",
        "js",
        "json",
        "nix",
        "toml",
        "ts",
        "typescript",
        "javascript",
        "ini"
    ],
    "blockTags": [
        "@defaultValue", "@deprecated", "@example", "@jsx", "@param",
        "@privateRemarks", "@remarks", "@returns", "@see", "@throws",
        "@typeParam", "@author", "@callback", "@category", "@categoryDescription",
        "@default", "@document", "@extends", "@augments", "@yields", "@group",
        "@groupDescription", "@import", "@inheritDoc", "@license", "@module",
        "@mergeModuleWith", "@prop", "@property", "@return", "@satisfies",
        "@since", "@sortStrategy", "@template", "@this", "@type", "@typedef",
        "@summary", "@preventInline", "@inlineType", "@preventExpand",
        "@expandType", "@fires"
    ],
    "externalSymbolLinkMappings": {
        "@girs/gio-2.0": {
            "Gio.Application": "#",
            "Gio.Application.SignalSignatures.activate": "#"
        },
        "@girs/gobject-2.0": {
            "GObject.ParamSpec": "#"
        },
        "@girs/gtk-3.0": {
            "Gtk.Label.use_markup": "#",
            "Gtk.Label.use_underline": "#"
        }
    },
    "intentionallyNotExported": [
        "Anchor",
        "AccessPointInfo",
        "Args",
        "B",
        "BarMode",
        "CairoContext",
        "Camel",
        "CommonProps",
        "Cursor",
        "Dep",
        "Detail",
        "DrawFn",
        "Event",
        "EventHandler",
        "Exclusivity",
        "Ico",
        "Instance",
        "Justification",
        "Kebab",
        "Keymode",
        "Layer",
        "Listen",
        "LoopStatus",
        "Mark",
        "MenuEventHandler",
        "MprisMetadata",
        "NotifcationJson",
        "PlaybackStatus",
        "Policy",
        "Poll",
        "PowerProfiles",
        "Response",
        "Services",
        "Transition",
        "Truncate"
    ]
}
