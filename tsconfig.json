{
    "compilerOptions": {
        "target": "ES2022",
        "module": "ES2022",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "allowJs": true,
        "checkJs": false,
        "outDir": "_build/tsc-out",
        "rootDir": "src",
        "strict": true,
        "moduleResolution": "bundler",
        "typeRoots": [
            "./node_modules/@girs"
        ],
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true
    },
    "include": [
        "node_modules/@girs/**/*-ambient.d.ts",
        "types/*",
        "src"
    ]
}
